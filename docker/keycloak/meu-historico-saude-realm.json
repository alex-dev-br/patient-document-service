{
  "realm": "meu-historico-saude",
  "displayName": "Meu Histórico Saúde",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "clientScopes": [
    {
      "name": "patients:read",
      "description": "Permite consultar pacientes",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "patients:write",
      "description": "Permite cadastrar pacientes",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "documents:read",
      "description": "Permite consultar documentos e resultados",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "documents:write",
      "description": "Permite enviar documentos",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "documents:file:read",
      "description": "Permite baixar o arquivo original de um documento",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "documents:ai-result:write",
      "description": "Permite atualizar manualmente o resultado da IA",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "patient-document-api-audience",
      "description": "Adiciona patient-document-api como audiência do token",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "patient-document-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "patient-document-api",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],

  "clients": [
    {
      "clientId": "patient-document-api",
      "name": "Patient Document API",
      "description": "Resource Server do Patient Document Service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    },
    {
      "clientId": "ai-processing-service",
      "name": "AI Processing Service",
      "description": "Cliente técnico utilizado pelo serviço de processamento de documentos",
      "enabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "${AI_PROCESSING_CLIENT_SECRET}",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "documents:file:read",
        "documents:ai-result:write",
        "patient-document-api-audience"
      ]
    },
    {
      "clientId": "patient-document-dev-client",
      "name": "Patient Document Development Client",
      "description": "Cliente técnico para testes locais da API",
      "enabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "${PATIENT_DOCUMENT_DEV_CLIENT_SECRET}",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "patients:read",
        "patients:write",
        "documents:read",
        "documents:write",
        "documents:file:read",
        "documents:ai-result:write",
        "patient-document-api-audience"
      ]
    }
  ]
}